---
/**
 * Minimal document shell for pages ported 1:1 from the original static site.
 * `head` and `body` are raw HTML fragments (see src/fragments/), so every
 * ported page renders byte-for-byte like the original. Global assets
 * (favicon, stylesheet, script.js) live here so they are managed in one place.
 */
interface Props {
  head: string;
  body: string;
}
const { head, body } = Astro.props;
const gaId = import.meta.env.PUBLIC_GA_ID;
const tm = head.match(/<title>([^<]*)<\/title>/i);
const ogTitle = tm ? tm[1].trim() : '';
const cm = head.match(/rel=["']canonical["']\s+href=["']([^"']+)["']/i);
const canonical = cm ? cm[1] : '';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <Fragment set:html={head} />
    {!head.includes("og:image") && (
      <meta property="og:image" content="https://onlinecasinolatino.com/logos/og-image.png" />
    )}
    {!head.includes('property="og:title"') && ogTitle && <meta property="og:title" content={ogTitle} />}
    {!head.includes('property="og:type"') && <meta property="og:type" content="website" />}
    {!head.includes('property="og:url"') && canonical && <meta property="og:url" content={canonical} />}
    {!head.includes("twitter:card") && (
      <meta name="twitter:card" content="summary_large_image" />
    )}
    {!head.includes('name="twitter:title"') && ogTitle && <meta name="twitter:title" content={ogTitle} />}
    {!head.includes('name="twitter:image"') && <meta name="twitter:image" content="https://onlinecasinolatino.com/logos/og-image.png" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/style.css" />
    {gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} is:inline></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId, { anonymize_ip: true });
        </script>
      </>
    )}
  </head>
  <body>
    <Fragment set:html={body} />
    <script src="/vendor/lenis.min.js" is:inline></script>
    <script src="/script.js" is:inline></script>
  </body>
</html>
